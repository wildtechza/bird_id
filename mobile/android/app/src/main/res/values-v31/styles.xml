<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ Splash Screen Theme with App Icon in Circle -->
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <!-- Splash screen background color -->
        <item name="android:windowSplashScreenBackground">#e07a1f</item>
        
        <!-- Use constrained layer-list to prevent icon clipping on Android 16 -->
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_icon</item>
        
        <!-- Match icon background to splash background to hide outline -->
        <item name="android:windowSplashScreenIconBackgroundColor">#e07a1f</item>
        
        <!-- Keep splash visible for smooth transition -->
        <item name="android:windowSplashScreenAnimationDuration">1000</item>
        
        <!-- Post splash screen theme -->
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
    </style>
</resources>
